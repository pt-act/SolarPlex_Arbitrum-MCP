{
  "name": "solarplex-arbitrum-mcp",
  "version": "1.1.0",
  "description": "Multi-chain MCP for SolarPlex agent - Solana, Arbitrum, Polygon, BSC, Ethereum, Base with GMX integration and RepuLayer reputation bridging",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "solarplex-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solana",
    "arbitrum",
    "polygon",
    "bsc",
    "ethereum",
    "base",
    "governance",
    "dao",
    "gmx",
    "reputation",
    "fairscore",
    "reputation-weighted",
    "quadratic-voting",
    "agent",
    "ai",
    "blockchain",
    "cross-chain"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pt-act/SolarPlex_Arbitrum-MCP.git"
  },
  "homepage": "https://solar-plex.netlify.app",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit",
    "prepublishOnly": "npm run build && npm run audit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana/web3.js": "^1.87.0",
    "ethers": "^6.11.0",
    "viem": "^2.47.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
